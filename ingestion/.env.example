# Copy to .env and fill in. .env is gitignored — credentials are never committed.
# Account Identifier: Snowsight -> Admin -> Accounts -> copy button.
# Format: <orgname>-<account_name>, e.g. ABCDEFG-XY12345
SNOWFLAKE_ACCOUNT=ABCDEFG-XY12345

# The username you set on the "Create your account" step (NOT your email).
SNOWFLAKE_USER=YOUR_USERNAME
SNOWFLAKE_PASSWORD=YOUR_PASSWORD

SNOWFLAKE_ROLE=AUSTENDER_DE
SNOWFLAKE_WAREHOUSE=AUSTENDER_WH
SNOWFLAKE_DATABASE=AUSTENDER_DB
SNOWFLAKE_SCHEMA=BRONZE
